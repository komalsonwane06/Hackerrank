#include <stdio.h>
#include <string.h>
#include <math.h>
#include <stdlib.h>

int main() {

    /* Enter your code here. Read input from STDIN. Print output to STDOUT */ 
    int n,k;
    scanf("%d",&n);
    int a[n];
    for(int i=0; i<n; ++i){
        scanf("%d", &a[i]);
    }
    scanf("%d", &k);
    
    int flag=-1;
    for(int i=0; i<n; ++i){
        if(k==a[i])
            flag=i;
    }
        printf("%d",flag);
    return 0;
}

